# Supabase — Settings > API in your project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
PORTAL_AUTH_SECRET=replace-with-a-long-random-secret

# Landing page CTAs (Microsoft Forms)
# NEXT_PUBLIC_TEAM_REGISTRATION_URL=https://forms.cloud.microsoft/r/your-team-form
# NEXT_PUBLIC_LOOKING_FOR_TEAM_URL=https://forms.cloud.microsoft/r/your-looking-for-team-form

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Landing page — set to true in Vercel after pre-event to show track names and full tracks section
# NEXT_PUBLIC_REVEAL_TRACKS_AND_JUDGES=true

# Submission window (ISO 8601 UTC). Leave either unset to remove that gate.
# SGT = UTC+8 — subtract 8h when writing UTC values.
# Example: open 24 Jul 10:00 SGT, deadline 25 Jul 12:00 SGT
# NEXT_PUBLIC_SUBMISSION_OPEN_AT=2026-07-24T02:00:00Z
# NEXT_PUBLIC_SUBMISSION_DEADLINE=2026-07-25T04:00:00Z
