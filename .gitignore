# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/tests/artifacts
/playwright-report
/test-results
playwright.config.ts
/tests

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep *.example templates committable
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ide / cursor (project-scoped MCP — secrets stay local)
.vscode
.cursor/mcp.json
.cursor/gdrive/*
!.cursor/gdrive/.gitkeep
client_secret*.json
*.HEIC

# temp downloads (Drive pull staging)
.tmp-drive

# claude code local settings
.claude/settings.local.json

# supabase
/supabase/entire_schema.sql
/supabase/migrations/20260612000000_create_activity_logs.sql

# screenshots
/screenshots